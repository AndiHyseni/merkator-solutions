<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let existing files/directories load normally.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # For React Router routes, always serve index.html.
  RewriteRule . /index.html [L]
</IfModule>
